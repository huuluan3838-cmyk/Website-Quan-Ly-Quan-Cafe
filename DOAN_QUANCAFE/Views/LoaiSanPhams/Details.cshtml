@model DOAN_QUANCAFE.tblLoaiSanPham

@{
    ViewBag.Title = "Chi tiết loại sản phẩm";
    Layout = "~/Views/Shared/_LayOutAdmin.cshtml";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary fw-bold">Chi Tiết Loại Sản Phẩm</h2>
        <a href="@Url.Action("Index")" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Quay lại
        </a>
    </div>

    <div class="row">
        <div class="col-md-4 mb-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 fw-bold text-secondary">Thông tin chung</h5>
                    <a href="@Url.Action("Edit", new { id = Model.MaLoai })" class="btn btn-sm btn-warning fw-bold text-dark">
                        <i class="bi bi-pencil-square"></i> Sửa
                    </a>
                </div>
                <div class="card-body">
                    <h3 class="text-primary fw-bold mb-3">
                        <i class="bi bi-tag-fill me-2"></i> @Model.TenLoai
                    </h3>

                    <ul class="list-group list-group-flush">
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <span class="fw-bold text-muted">Mã loại:</span>
                            <span class="badge bg-secondary">#@Model.MaLoai</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <span class="fw-bold text-muted">Số lượng món:</span>
                            <span class="badge bg-primary rounded-pill">
                                @(Model.tblSanPhams != null ? Model.tblSanPhams.Count : 0) món
                            </span>
                        </li>
                    </ul>

                    <div class="mt-4">
                        <label class="fw-bold text-muted mb-2">Ghi chú / Mô tả:</label>
                        <div class="p-3 bg-light rounded border text-muted">
                            @(string.IsNullOrEmpty(Model.GhiChu) ? "Không có ghi chú nào." : Model.GhiChu)
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0 fw-bold text-secondary">Danh sách món thuộc nhóm "@Model.TenLoai"</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-light">
                                <tr>
                                    <th class="ps-4">Tên món</th>
                                    <th>Giá bán</th>
                                    <th>Kích thước</th>
                                    <th>Trạng thái</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.tblSanPhams != null && Model.tblSanPhams.Count > 0)
                                {
                                    foreach (var sp in Model.tblSanPhams)
                                    {
                                        <tr>
                                            <td class="ps-4 fw-bold">@sp.TenSP</td>
                                            <td class="text-danger fw-bold">@String.Format("{0:N0}", sp.GiaBan) đ</td>
                                            <td><span class="badge bg-light text-dark border">@(sp.KichThuoc ?? "-")</span></td>
                                            <td><span class="badge bg-success bg-opacity-10 text-success">Đang bán</span></td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="4" class="text-center py-4 text-muted fst-italic">
                                            Chưa có món ăn nào trong nhóm này.
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>