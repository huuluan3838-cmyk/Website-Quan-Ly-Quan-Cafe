@model IEnumerable<DOAN_QUANCAFE.tblLoaiSanPham>

@{
    ViewBag.Title = "Quản lý Loại sản phẩm";
    Layout = "~/Views/Shared/_LayOutAdmin.cshtml";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="text-primary fw-bold">Loại Sản Phẩm</h2>
            <p class="text-muted">Phân loại thực đơn của quán.</p>
        </div>
        <a href="@Url.Action("Create")" class="btn btn-primary shadow-sm">
            <i class="bi bi-plus-lg"></i> Thêm Loại Mới
        </a>
    </div>

    <div class="row">
        <div class="col-md-12">
            <div class="card shadow-sm border-0">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover table-striped align-middle mb-0">
                            <thead class="bg-light text-secondary">
                                <tr>
                                    <th class="ps-4">Tên loại</th>
                                    <th>Ghi chú / Mô tả</th>
                                    <th class="text-center">Số lượng món</th>
                                    <th class="text-center" style="width: 150px;">Thao tác</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td class="ps-4 fw-bold text-primary">
                                            <i class="bi bi-tag-fill me-2 text-secondary"></i> @item.TenLoai
                                        </td>

                                        <td class="text-muted">
                                            @(string.IsNullOrEmpty(item.GhiChu) ? "Không có ghi chú" : item.GhiChu)
                                        </td>

                                        <td class="text-center">
                                            <span class="badge bg-secondary rounded-pill">
                                                @(item.tblSanPhams != null ? item.tblSanPhams.Count : 0) món
                                            </span>
                                        </td>

                                        @*<td class="text-center">
                                            <div class="btn-group" role="group">
                                                <a href="@Url.Action("Edit", new { id = item.MaLoai })" class="btn btn-sm btn-outline-warning" title="Sửa">
                                                    <i class="bi bi-pencil-fill"></i>
                                                </a>
                                                <a href="@Url.Action("Details", new { id = item.MaLoai })" class="btn btn-sm btn-outline-info" title="Chi tiết">
                                                    <i class="bi bi-eye-fill"></i>
                                                </a>
                                                <a href="@Url.Action("Delete", new { id = item.MaLoai })" class="btn btn-sm btn-outline-danger" title="Xóa">
                                                    <i class="bi bi-trash-fill"></i>
                                                </a>
                                            </div>
                                        </td>*@
                                        <td class="text-center">
                                            <div class="btn-group" role="group">
                                                <a href="@Url.Action("Edit", new { id = item.MaLoai })" class="btn btn-sm btn-outline-warning" title="Sửa">
                                                    ✏️
                                                </a>
                                                <a href="@Url.Action("Details", new { id = item.MaLoai })" class="btn btn-sm btn-outline-info" title="Chi tiết">
                                                    👁️
                                                </a>
                                                <a href="@Url.Action("Delete", new { id = item.MaLoai })" class="btn btn-sm btn-outline-danger" title="Xóa">
                                                    🗑️
                                                </a>
                                            </div>
                                        </td>
                                    </tr>
                                }

                                @if (Model.Count() == 0)
                                {
                                    <tr>
                                        <td colspan="4" class="text-center py-4 text-muted">
                                            Chưa có loại sản phẩm nào.
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>