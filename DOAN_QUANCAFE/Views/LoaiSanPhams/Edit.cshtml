@model DOAN_QUANCAFE.tblLoaiSanPham

@{
    ViewBag.Title = "Sửa loại sản phẩm";
    Layout = "~/Views/Shared/_LayOutAdmin.cshtml";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-warning text-dark fw-bold">Chỉnh Sửa Loại</h2>
        <a href="@Url.Action("Index")" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Quay lại
        </a>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    @using (Html.BeginForm())
                    {
                        @Html.AntiForgeryToken()
                        @Html.HiddenFor(model => model.MaLoai)
                        @Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })

                        <div class="mb-3">
                            <label class="form-label fw-bold">Tên loại sản phẩm <span class="text-danger">*</span></label>
                            @Html.EditorFor(model => model.TenLoai, new { htmlAttributes = new { @class = "form-control form-control-lg fw-bold text-primary" } })
                            @Html.ValidationMessageFor(model => model.TenLoai, "", new { @class = "text-danger" })
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold">Ghi chú</label>
                            @Html.TextAreaFor(model => model.GhiChu, new { @class = "form-control", rows = "3" })
                            @Html.ValidationMessageFor(model => model.GhiChu, "", new { @class = "text-danger" })
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-warning fw-bold text-dark btn-lg">
                                <i class="bi bi-check-circle-fill"></i> Cập Nhật
                            </button>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>