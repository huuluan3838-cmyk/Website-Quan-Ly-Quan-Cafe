@model DOAN_QUANCAFE.tblSanPham

@{
    ViewBag.Title = "Xóa sản phẩm";
    Layout = "~/Views/Shared/_LayOutAdmin.cshtml";
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">
        @TempData["ErrorMessage"]
    </div>
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-danger fw-bold">Xóa Sản Phẩm</h2>
        <a href="@Url.Action("Index")" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Quay lại danh sách
        </a>
    </div>

    <div class="card border-danger shadow-sm">
        <div class="card-header bg-danger text-white">
            <h5 class="mb-0">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                Cảnh báo: Bạn có chắc chắn muốn xóa sản phẩm này không?
            </h5>
        </div>

        <div class="card-body">
            <div class="row">
                <div class="col-md-4 text-center mb-3">
                    <div class="p-3 border rounded bg-light">
                        <img src="~/Content/Images/Products/@(Model.HinhAnh)"
                             alt="@Model.TenSP"
                             class="img-fluid rounded shadow-sm"
                             style="max-height: 300px; object-fit: contain;"
                             onerror="this.onerror=null; this.src='https://via.placeholder.com/300?text=No+Image';" />
                    </div>
                    <div class="mt-2 text-muted fst-italic">Hình ảnh sản phẩm</div>
                </div>

                <div class="col-md-8">
                    <h3 class="text-primary fw-bold mb-3">@Model.TenSP</h3>

                    <div class="table-responsive">
                        <table class="table table-borderless">
                            <tbody>
                                <tr>
                                    <td class="fw-bold text-secondary" style="width: 150px;">Mã sản phẩm:</td>
                                    <td><span class="badge bg-secondary">#@Model.MaSP</span></td>
                                </tr>
                                <tr>
                                    <td class="fw-bold text-secondary">Giá bán:</td>
                                    <td class="fs-5 text-danger fw-bold">@String.Format("{0:N0}", Model.GiaBan) VNĐ</td>
                                </tr>
                                <tr>
                                    <td class="fw-bold text-secondary">Kích thước:</td>
                                    <td>@(Model.KichThuoc ?? "Chưa cập nhật")</td>
                                </tr>
                                <tr>
                                    <td class="fw-bold text-secondary">Loại sản phẩm:</td>
                                    <td>
                                        <span class="badge bg-info text-dark">
                                            @(Model.tblLoaiSanPham != null ? Model.tblLoaiSanPham.TenLoai : "Không xác định")
                                        </span>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="fw-bold text-secondary">Nhà cung cấp:</td>
                                    <td>@(Model.tblNhaCungCap != null ? Model.tblNhaCungCap.TenNCC : "Không xác định")</td>
                                </tr>
                                <tr>
                                    <td class="fw-bold text-secondary">Mô tả:</td>
                                    <td class="text-muted">@(string.IsNullOrEmpty(Model.MoTa) ? "Không có mô tả" : Model.MoTa)</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="card-footer bg-light d-flex justify-content-end gap-2 py-3">
            @using (Html.BeginForm())
            {
                @Html.AntiForgeryToken()

                <a href="@Url.Action("Index")" class="btn btn-secondary px-4">
                    Hủy bỏ
                </a>
                <button type="submit" class="btn btn-danger px-4 fw-bold">
                    <i class="bi bi-trash-fill"></i> Xác nhận Xóa
                </button>
            }
        </div>
    </div>
</div>