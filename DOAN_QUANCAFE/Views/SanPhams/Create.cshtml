@model DOAN_QUANCAFE.tblSanPham

@{
    ViewBag.Title = "Thêm sản phẩm mới";
    Layout = "~/Views/Shared/_LayOutAdmin.cshtml";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary fw-bold">Thêm Sản Phẩm Mới</h2>
        <a href="@Url.Action("Index")" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Quay lại danh sách
        </a>
    </div>

    @using (Html.BeginForm("Create", "SanPhams", FormMethod.Post, new { enctype = "multipart/form-data" }))
    {
        @Html.AntiForgeryToken()

        <div class="row">
            <div class="col-md-4 mb-4">
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-white py-3">
                        <h5 class="mb-0 fw-bold text-secondary">Hình ảnh</h5>
                    </div>
                    <div class="card-body text-center">
                        <div class="img-preview-container mb-3" style="width: 100%; height: 300px; border: 2px dashed #ddd; border-radius: 8px; display: flex; align-items: center; justify-content: center; overflow: hidden; background: #f9f9f9;">

                            <img id="imgPreview"
                                 src="~/Content/Images/Products/placeholder.jpg"
                                 alt="Ảnh xem trước"
                                 style="max-width: 100%; max-height: 100%; object-fit: contain;"
                                 onerror="this.onerror=null; this.src='https://via.placeholder.com/300?text=Upload+Anh';" />
                        </div>

                        <label for="uploadHinh" class="btn btn-primary w-100">
                            <i class="bi bi-upload"></i> Chọn hình ảnh
                        </label>
                        <input type="file" name="uploadHinh" id="uploadHinh" accept="image/*" class="d-none" onchange="previewImage(this)" />

                        <small class="text-muted d-block mt-2">Chấp nhận: .jpg, .png, .jpeg</small>
                        @Html.ValidationMessageFor(model => model.HinhAnh, "", new { @class = "text-danger mt-2" })
                    </div>
                </div>
            </div>

            <div class="col-md-8">
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-white py-3">
                        <h5 class="mb-0 fw-bold text-secondary">Thông tin chung</h5>
                    </div>
                    <div class="card-body">
                        @Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })

                        <div class="row">
                            <div class="col-md-12 mb-3">
                                <label class="form-label fw-bold">Tên sản phẩm <span class="text-danger">*</span></label>
                                @Html.EditorFor(model => model.TenSP, new { htmlAttributes = new { @class = "form-control form-control-lg", placeholder = "Ví dụ: Cà phê sữa đá" } })
                                @Html.ValidationMessageFor(model => model.TenSP, "", new { @class = "text-danger" })
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Giá bán (VNĐ) <span class="text-danger">*</span></label>
                                @Html.EditorFor(model => model.GiaBan, new { htmlAttributes = new { @class = "form-control", type = "number", min = "0", step = "1000" } })
                                @Html.ValidationMessageFor(model => model.GiaBan, "", new { @class = "text-danger" })
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Kích thước</label>
                                @Html.EditorFor(model => model.KichThuoc, new { htmlAttributes = new { @class = "form-control", placeholder = "S, M, L hoặc 500ml..." } })
                                @Html.ValidationMessageFor(model => model.KichThuoc, "", new { @class = "text-danger" })
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Loại sản phẩm <span class="text-danger">*</span></label>
                                @Html.DropDownList("LoaiSP", null, "-- Chọn loại --", htmlAttributes: new { @class = "form-select" })
                                @Html.ValidationMessageFor(model => model.LoaiSP, "", new { @class = "text-danger" })
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Nhà cung cấp <span class="text-danger">*</span></label>
                                @Html.DropDownList("NhaCungCap", null, "-- Chọn nhà cung cấp --", htmlAttributes: new { @class = "form-select" })
                                @Html.ValidationMessageFor(model => model.NhaCungCap, "", new { @class = "text-danger" })
                            </div>

                            <div class="col-md-12 mb-4">
                                <label class="form-label fw-bold">Mô tả sản phẩm</label>
                                @Html.TextAreaFor(model => model.MoTa, new { @class = "form-control", rows = "5", placeholder = "Nhập mô tả chi tiết..." })
                                @Html.ValidationMessageFor(model => model.MoTa, "", new { @class = "text-danger" })
                            </div>
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <a href="@Url.Action("Index")" class="btn btn-light me-md-2">Hủy bỏ</a>
                            <button type="submit" class="btn btn-primary px-5 fw-bold">
                                <i class="bi bi-save"></i> Lưu Sản Phẩm
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<script>
    function previewImage(input) {
        if (input.files && input.files[0]) {
            var reader = new FileReader();
            reader.onload = function (e) {
                var img = document.getElementById('imgPreview');
                img.src = e.target.result;
                img.onerror = null;
            }
            reader.readAsDataURL(input.files[0]);
        }
    }
</script>