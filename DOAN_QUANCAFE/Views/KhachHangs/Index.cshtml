@model IEnumerable<DOAN_QUANCAFE.tblKhachHang>

@{
    ViewBag.Title = "Quản lý khách hàng";
    Layout = "~/Views/Shared/_LayOutAdmin.cshtml";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="text-primary fw-bold">Danh Sách Khách Hàng</h2>
            <p class="text-muted">Quản lý thông tin và lịch sử mua hàng.</p>
        </div>
        <a href="@Url.Action("Create")" class="btn btn-primary shadow-sm">
            <i class="bi bi-person-plus-fill"></i> Thêm Khách Hàng
        </a>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">
            <i class="bi bi-exclamation-triangle-fill"></i> @TempData["Error"]
        </div>
    }

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light text-secondary">
                        <tr>
                            <th class="ps-4">Khách hàng</th>
                            <th>Liên hệ</th>
                            <th>Địa chỉ</th>
                            <th class="text-center">Số đơn đã mua</th>
                            <th class="text-center">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center">
                                        <img src="~/Content/Images/avt/@item.Avarta"
                                             class="rounded-circle border"
                                             style="width: 50px; height: 50px; object-fit: cover; margin-right: 15px;"
                                             onerror="this.onerror=null;this.src='~/Content/Images/avt/default-user.jpg';" />
                                        <div>
                                            <div class="fw-bold text-dark">@item.TenKH</div>
                                            <small class="text-muted">@item.GioiTinh - @item.NamSinh</small>
                                        </div>
                                    </div>
                                </td>

                                <td>
                                    <div class="d-flex flex-column">
                                        <span><i class="bi bi-telephone-fill text-muted me-2 small"></i>@item.DienThoai</span>
                                        <span class="text-muted small"><i class="bi bi-envelope-fill text-muted me-2 small"></i>@(item.Email ?? "Chưa cập nhật")</span>
                                    </div>
                                </td>

                                <td class="text-muted" style="max-width: 250px;">
                                    <i class="bi bi-geo-alt-fill text-muted me-1"></i> @(item.DiaChi ?? "Chưa cập nhật")
                                </td>

                                <td class="text-center">
                                    <span class="badge bg-info text-dark rounded-pill">
                                        @(item.tblHoaDons != null ? item.tblHoaDons.Count : 0) đơn
                                    </span>
                                </td>

                                @*<td class="text-center">
            <div class="btn-group" role="group">
                <a href="@Url.Action("Edit", new { id = item.MaKH })" class="btn btn-sm btn-outline-warning" title="Sửa">
                    <i class="bi bi-pencil-fill"></i>
                </a>
                <a href="@Url.Action("Details", new { id = item.MaKH })" class="btn btn-sm btn-outline-info" title="Chi tiết">
                    <i class="bi bi-eye-fill"></i>
                </a>
                <a href="@Url.Action("Delete", new { id = item.MaKH })" class="btn btn-sm btn-outline-danger" title="Xóa">
                    <i class="bi bi-trash-fill"></i>
                </a>
            </div>
        </td>*@
                                <td class="text-center">
                                    <div class="btn-group" role="group">
                                        <a href="@Url.Action("Edit", new { id = item.MaKH })" class="btn btn-sm btn-outline-warning" title="Sửa">
                                            ✏️
                                        </a>
                                        <a href="@Url.Action("Details", new { id = item.MaKH })" class="btn btn-sm btn-outline-info" title="Chi tiết">
                                            👁️
                                        </a>
                                        <a href="@Url.Action("Delete", new { id = item.MaKH })" class="btn btn-sm btn-outline-danger" title="Xóa">
                                            🗑️
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>