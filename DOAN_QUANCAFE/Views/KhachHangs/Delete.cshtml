@model DOAN_QUANCAFE.tblKhachHang
@{
    ViewBag.Title = "Xóa khách hàng";
    Layout = "~/Views/Shared/_LayOutAdmin.cshtml";
}

<style>
    .del-wrap {
        max-width: 1100px;
    }

    .del-hero {
        background: linear-gradient(135deg, rgba(220,53,69,.16) 0%, rgba(255,193,7,.10) 100%);
        border: 1px solid rgba(220,53,69,.20);
        border-radius: 18px;
        padding: 18px;
        box-shadow: 0 10px 30px rgba(0,0,0,.06);
    }

    .del-title {
        margin: 0;
        font-weight: 900;
        letter-spacing: .3px;
    }

    .del-sub {
        margin: 6px 0 0;
        color: #6c757d;
        font-weight: 600;
    }

    .del-card {
        background: #fff;
        border: 1px solid rgba(0,0,0,.10);
        border-radius: 18px;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(0,0,0,.06);
    }

    .del-card-hd {
        padding: 14px 16px;
        border-bottom: 1px solid rgba(0,0,0,.06);
        background: rgba(248,249,250,.85);
        backdrop-filter: blur(6px);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
        flex-wrap: wrap;
    }

    .del-body {
        padding: 18px;
    }

    .del-avatar {
        width: 130px;
        height: 130px;
        object-fit: cover;
        border-radius: 999px;
        border: 6px solid rgba(255,255,255,.95);
        box-shadow: 0 16px 30px rgba(0,0,0,.12);
        background: #fff;
    }

    .del-warn {
        border: 1px solid rgba(255,193,7,.35);
        background: rgba(255,193,7,.12);
        border-radius: 16px;
        padding: 14px 14px;
        text-align: left;
        display: inline-block;
        max-width: 560px;
    }

        .del-warn ul {
            margin: 8px 0 0;
            padding-left: 18px;
        }

        .del-warn li {
            margin: 4px 0;
        }

    .btn-pill {
        border-radius: 999px;
        padding: 10px 14px;
        font-weight: 900;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }
</style>


    <div class="row justify-content-center">
        <div class="col-lg-8 col-xl-7">
            <div class="del-card">
                <div class="del-card-hd">
                    <div class="fw-bold text-danger">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i> XÁC NHẬN XÓA
                    </div>
                    <span class="badge text-bg-danger" style="border-radius:999px; padding:8px 12px; font-weight:900;">
                        Không thể hoàn tác
                    </span>
                </div>

                <div class="del-body text-center">
                    <img src="~/Content/Images/avt/@(Model.Avarta ?? "default-user.jpg")"
                         class="del-avatar"
                         alt="@Model.TenKH"
                         onerror="this.onerror=null;this.src='/Content/Images/Avatar/default-user.jpg';" />

                    <h3 class="mt-3 mb-0 fw-bold text-dark">@Model.TenKH</h3>
                    <div class="text-muted fw-semibold mt-1">@Model.DienThoai</div>

                    <div class="mt-4 del-warn">
                        <div class="fw-bold text-dark">
                            <i class="bi bi-info-circle-fill me-2"></i>Lưu ý
                        </div>
                        <ul class="small mb-0">
                            <li>Hành động này không thể hoàn tác.</li>
                            <li>Nếu khách hàng đã có đơn hàng, hệ thống sẽ không cho phép xóa do ràng buộc dữ liệu.</li>
                        </ul>
                    </div>

                    <div class="mt-4 pt-3 border-top d-flex justify-content-center gap-2 flex-wrap">
                        @using (Html.BeginForm())
                        {
                            @Html.AntiForgeryToken()

                            <a href="@Url.Action("Index")" class="btn btn-outline-secondary btn-pill">
                                <i class="bi bi-x-circle"></i> Hủy bỏ
                            </a>

                            <button type="submit" class="btn btn-danger btn-pill">
                                <i class="bi bi-trash-fill"></i> Xác nhận xóa
                            </button>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
