@model DOAN_QUANCAFE.tblKhachHang
@{
    ViewBag.Title = "Thêm khách hàng";
    Layout = "~/Views/Shared/_LayOutAdmin.cshtml";
}

<style>
    .ac-wrap {
        max-width: 1200px;
    }

    .ac-hero {
        background: linear-gradient(135deg, rgba(111,78,55,.14) 0%, rgba(255,215,0,.10) 100%);
        border: 1px solid rgba(0,0,0,.10);
        border-radius: 18px;
        padding: 18px;
        box-shadow: 0 10px 30px rgba(0,0,0,.06);
    }

    .ac-title {
        margin: 0;
        font-weight: 900;
        letter-spacing: .3px;
    }

    .ac-sub {
        margin: 6px 0 0;
        color: #6c757d;
        font-weight: 600;
    }

    .ac-card {
        background: #fff;
        border: 1px solid rgba(0,0,0,.10);
        border-radius: 18px;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(0,0,0,.06);
        height: 100%;
    }

    .ac-card-hd {
        padding: 14px 16px;
        border-bottom: 1px solid rgba(0,0,0,.06);
        background: rgba(248,249,250,.85);
        backdrop-filter: blur(6px);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
        flex-wrap: wrap;
    }

    .ac-card-bd {
        padding: 16px;
    }

    .ac-avatar {
        width: 180px;
        height: 180px;
        border-radius: 999px;
        object-fit: cover;
        border: 6px solid rgba(255,255,255,.95);
        box-shadow: 0 16px 30px rgba(0,0,0,.12);
        background: #fff;
    }

    .ac-hint {
        margin: 10px 0 0;
        color: #6c757d;
        font-weight: 600;
        font-size: 13px;
    }

    .ac-label {
        font-weight: 900;
    }

    .ac-input .form-control,
    .ac-input .form-select,
    .ac-input textarea {
        border-radius: 14px;
        padding: 10px 12px;
    }

    .btn-pill {
        border-radius: 999px;
        padding: 10px 14px;
        font-weight: 900;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }
</style>

<div class="container-fluid ac-wrap mt-3 mb-4">
    <div class="ac-hero mb-3">
        <div class="d-flex flex-wrap align-items-center justify-content-between gap-2">
            <div>
                <h2 class="ac-title text-primary">THÊM KHÁCH HÀNG MỚI</h2>
                <div class="ac-sub">Nhập thông tin và tải ảnh đại diện</div>
            </div>
            <a href="javascript:history.back()" class="btn btn-outline-secondary btn-pill">
                <i class="fas fa-arrow-left"></i> Quay lại
            </a>
        </div>
    </div>

    @using (Html.BeginForm("Create", "KhachHangs", FormMethod.Post, new { enctype = "multipart/form-data" }))
    {
        @Html.AntiForgeryToken()

        <div class="row g-3">
            <!-- Avatar -->
            <div class="col-lg-4">
                <div class="ac-card">
                    <div class="ac-card-hd">
                        <div class="fw-bold text-dark"><i class="fas fa-image me-2"></i>Ảnh đại diện</div>
                    </div>
                    <div class="ac-card-bd text-center">
                        <img id="imgPreview"
                             class="ac-avatar"
                             src="~/Content/Images/avt/default-user.jpg"
                             alt="Avatar" />

                        <div class="ac-hint">Chọn ảnh để xem trước</div>

                        <div class="mt-3 ac-input">
                            <input id="uploadHinh" type="file" name="uploadHinh" class="form-control" accept="image/*" />
                            <div class="form-text">Khuyến nghị: JPG/PNG, ảnh vuông hiển thị đẹp hơn.</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Form -->
            <div class="col-lg-8">
                <div class="ac-card">
                    <div class="ac-card-hd">
                        <div class="fw-bold text-dark"><i class="fas fa-user-plus me-2"></i>Thông tin khách hàng</div>
                    </div>

                    <div class="ac-card-bd ac-input">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label ac-label">Họ tên (*)</label>
                                @Html.TextBoxFor(m => m.TenKH, new { @class = "form-control", required = "required", placeholder = "Nhập họ tên" })
                                @Html.ValidationMessageFor(m => m.TenKH, "", new { @class = "text-danger" })
                            </div>

                            <div class="col-md-6">
                                <label class="form-label ac-label">Điện thoại</label>
                                @Html.TextBoxFor(m => m.DienThoai, new { @class = "form-control", placeholder = "Nhập số điện thoại" })
                                @Html.ValidationMessageFor(m => m.DienThoai, "", new { @class = "text-danger" })
                            </div>

                            <div class="col-md-6">
                                <label class="form-label ac-label">Mật khẩu (mặc định)</label>
                                @Html.TextBoxFor(m => m.MatKhau, new { @class = "form-control", @Value = "123456" })
                                <div class="form-text">Có thể đổi sau khi tạo khách hàng.</div>
                            </div>

                            <div class="col-md-3">
                                <label class="form-label ac-label">Giới tính</label>
                                @Html.DropDownListFor(
                                    m => m.GioiTinh,
                                    new SelectList(new[] { "Nam", "Nữ" }),
                                    "Chọn",
                                    new { @class = "form-select" }
                                )
                                @Html.ValidationMessageFor(m => m.GioiTinh, "", new { @class = "text-danger" })
                            </div>

                            <div class="col-md-3">
                                <label class="form-label ac-label">Năm sinh</label>
                                @Html.TextBoxFor(m => m.NamSinh, new { @class = "form-control", type = "number", min = "1900", max = "2100", placeholder = "VD: 2003" })
                                @Html.ValidationMessageFor(m => m.NamSinh, "", new { @class = "text-danger" })
                            </div>

                            <div class="col-12">
                                <label class="form-label ac-label">Địa chỉ</label>
                                @Html.TextAreaFor(m => m.DiaChi, new { @class = "form-control", rows = 2, placeholder = "Nhập địa chỉ" })
                                @Html.ValidationMessageFor(m => m.DiaChi, "", new { @class = "text-danger" })
                            </div>

                            <div class="col-12 d-flex gap-2 flex-wrap mt-2">
                                <button type="submit" class="btn btn-primary btn-pill">
                                    <i class="fas fa-save"></i> Lưu khách hàng
                                </button>
                                <a href="@Url.Action("Index", "KhachHangs")" class="btn btn-outline-secondary btn-pill">
                                    <i class="fas fa-times"></i> Hủy
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<script>
    (function () {
        const input = document.getElementById('uploadHinh');
        const img = document.getElementById('imgPreview');
        if (!input || !img) return;

        input.addEventListener('change', function () {
            const f = this.files && this.files[0];
            if (!f) return;
            if (!f.type || !f.type.startsWith('image/')) return;

            img.src = URL.createObjectURL(f);
        });
    })();
</script>
