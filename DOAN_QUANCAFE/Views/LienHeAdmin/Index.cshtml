@model IEnumerable<DOAN_QUANCAFE.LienHe>

@{
    ViewBag.Title = "Quản lý liên hệ";
    Layout = "~/Views/Shared/_LayOutAdmin.cshtml";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="text-primary fw-bold">Quản lý Liên hệ</h2>
            <p class="text-muted">Xem các tin nhắn liên hệ từ khách hàng gửi về hệ thống.</p>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light text-secondary">
                        <tr>
                            <th class="ps-4">#</th>
                            <th>Họ tên</th>
                            <th>Email/SĐT</th>
                            <th>Nội dung</th>
                            <th>Ngày gửi</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="5" class="text-center py-4 text-muted">Chưa có liên hệ nào.</td>
                            </tr>
                        }
                        else
                        {
                            foreach (var item in Model.OrderByDescending(x => x.NgayGui))
                            {
                                <tr>
                                    <td class="ps-4 fw-bold text-muted">@item.Id</td>

                                    <td>
                                        <div class="fw-bold text-dark">@item.HoTen</div>
                                    </td>

                                    <td>
                                        <div class="text-dark">@item.EmailOrPhone</div>
                                    </td>

                                    <td>
                                        <span class="text-break">@item.NoiDung</span>
                                    </td>

                                    <td>
                                        @item.NgayGui.ToString("dd/MM/yyyy HH:mm")
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
