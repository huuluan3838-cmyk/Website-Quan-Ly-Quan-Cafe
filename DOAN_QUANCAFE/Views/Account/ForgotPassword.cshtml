@{ Layout = null; }
<!DOCTYPE html>
<html>
<head>
    <link href="~/Content/bootstrap/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css">
    <style>
        body {
            background: linear-gradient(135deg, #6B4423 0%, #8B5A3C 100%);
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .card {
            background: white;
            padding: 40px;
            border-radius: 15px;
            width: 100%;
            max-width: 420px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.3);
        }

        .btn-brown {
            background: #6B4423;
            color: white;
            border-radius: 25px;
            padding: 12px;
            font-weight: bold;
            width: 100%;
            border: none;
        }
    </style>
</head>
<body>
    <div class="card text-center">
        <h3 class="fw-bold" style="color: #6B4423;">QUÊN MẬT KHẨU</h3>
        <p class="text-muted">Nhập email để nhận mã xác nhận OTP</p>

        @if (ViewBag.Error != null)
        {<div class="alert alert-danger">@ViewBag.Error</div>}

        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()
            <div class="mb-4 text-start">
                <label class="form-label fw-bold">Email đăng ký</label>
                <input type="email" name="email" class="form-control" placeholder="example@gmail.com" required />
            </div>
            <button type="submit" class="btn btn-brown shadow">GỬI MÃ XÁC NHẬN</button>
            <div class="mt-3">
                <a href="@Url.Action("Login")" style="color: #6B4423; text-decoration: none;"> Quay lại Đăng nhập</a>
            </div>
        }
    </div>
</body>
</html>