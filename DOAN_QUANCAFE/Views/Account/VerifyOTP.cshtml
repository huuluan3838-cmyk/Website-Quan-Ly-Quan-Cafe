@{ Layout = null; }
<!DOCTYPE html>
<html>
<head>
    <link href="~/Content/bootstrap/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body {
            background: linear-gradient(135deg, #6B4423 0%, #8B5A3C 100%);
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .card {
            background: white;
            padding: 40px;
            border-radius: 15px;
            width: 100%;
            max-width: 420px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.3);
        }

        .btn-brown {
            background: #6B4423;
            color: white;
            border-radius: 25px;
            padding: 12px;
            font-weight: bold;
            width: 100%;
            border: none;
        }
    </style>
</head>
<body>
    <div class="card text-center">
        <h3 class="fw-bold" style="color: #6B4423;">ĐẶT MẬT KHẨU MỚI</h3>
        <p class="text-muted">Kiểm tra email để lấy mã OTP 6 số</p>

        @if (ViewBag.Error != null)
        {<div class="alert alert-danger">@ViewBag.Error</div>}

        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()
            <div class="mb-3 text-start">
                <label class="form-label fw-bold">Mã xác nhận (OTP)</label>
                <input type="text" name="otp" class="form-control text-center fw-bold" placeholder="000000" maxlength="6" required />
            </div>
            <div class="mb-3 text-start">
                <label class="form-label fw-bold">Mật khẩu mới</label>
                <input type="password" name="newPassword" class="form-control" placeholder="••••••" required />
            </div>
            <div class="mb-4 text-start">
                <label class="form-label fw-bold">Xác nhận mật khẩu mới</label>
                <input type="password" name="confirmPassword" class="form-control" placeholder="••••••" required />
            </div>
            <button type="submit" class="btn btn-brown shadow">HOÀN TẤT ĐỔI MẬT KHẨU</button>
        }
    </div>
</body>
</html>