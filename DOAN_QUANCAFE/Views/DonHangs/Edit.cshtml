@model DOAN_QUANCAFE.tblHoaDon

@{
    ViewBag.Title = "Cập nhật đơn hàng";
    Layout = "~/Views/Shared/_LayOutAdmin.cshtml";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-warning text-dark fw-bold">Cập Nhật Trạng Thái Đơn #@Model.MaHD</h2>
        <a href="@Url.Action("Index")" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Quay lại
        </a>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    @using (Html.BeginForm())
                    {
                        @Html.AntiForgeryToken()
                        @Html.HiddenFor(model => model.MaHD)
                        @Html.HiddenFor(model => model.MaKH)
                        @Html.HiddenFor(model => model.NgayLap)
                        @Html.HiddenFor(model => model.TongTien)
                        @Html.HiddenFor(model => model.DiaChiGiaoHang)
                        <div class="alert alert-info">
                            <i class="bi bi-info-circle-fill me-2"></i>
                            Bạn đang cập nhật cho đơn hàng của khách: <strong>@(Model.tblKhachHang != null ? Model.tblKhachHang.TenKH : "Vãng lai")</strong>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold">Trạng thái đơn hàng</label>
                            @Html.DropDownList("TinhTrang", null, htmlAttributes: new { @class = "form-select form-select-lg" })
                            @Html.ValidationMessageFor(model => model.TinhTrang, "", new { @class = "text-danger" })
                        </div>

                        <div class="mb-4">
                            <div class="form-check form-switch p-3 border rounded bg-light">
                                @Html.CheckBox("DaThanhToan", Model.DaThanhToan ?? false, new { @class = "form-check-input", @id = "DaThanhToan" })

                                <label class="form-check-label fw-bold ms-2" for="DaThanhToan">
                                    Đã thanh toán tiền
                                </label>
                            </div>
                            @Html.ValidationMessageFor(model => model.DaThanhToan, "", new { @class = "text-danger" })
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold">Nhân viên phụ trách</label>
                            @Html.DropDownList("MaNV", null, "-- Chọn nhân viên --", htmlAttributes: new { @class = "form-select" })
                            @Html.ValidationMessageFor(model => model.MaNV, "", new { @class = "text-danger" })
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-warning fw-bold text-dark btn-lg">
                                <i class="bi bi-check-circle-fill"></i> Lưu Cập Nhật
                            </button>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>