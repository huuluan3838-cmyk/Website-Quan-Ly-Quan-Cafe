@model DOAN_QUANCAFE.tblHoaDon

@{
    ViewBag.Title = "Xóa đơn hàng";
    Layout = "~/Views/Shared/_LayOutAdmin.cshtml";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-danger fw-bold">Xóa Đơn Hàng</h2>
        <a href="@Url.Action("Index")" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Quay lại
        </a>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card border-danger shadow-sm">
                <div class="card-header bg-danger text-white">
                    <h5 class="mb-0">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                        Cảnh báo hành động nguy hiểm
                    </h5>
                </div>

                <div class="card-body text-center py-5">
                    <h3 class="text-dark fw-bold mb-3">Bạn có chắc muốn xóa Đơn hàng #@Model.MaHD?</h3>

                    <div class="alert alert-warning d-inline-block text-start mb-4">
                        <i class="bi bi-info-circle-fill me-2"></i> Thông tin đơn hàng sẽ bị xóa vĩnh viễn:
                        <ul class="mb-0 mt-2">
                            <li><strong>Khách hàng:</strong> @(Model.tblKhachHang != null ? Model.tblKhachHang.TenKH : "Vãng lai")</li>
                            <li><strong>Ngày đặt:</strong> @String.Format("{0:dd/MM/yyyy}", Model.NgayLap)</li>
                            <li><strong>Tổng tiền:</strong> @String.Format("{0:N0}", Model.TongTien) đ</li>
                            <li><strong>Số lượng món:</strong> @Model.tblChiTietHoaDons.Count món</li>
                        </ul>
                    </div>

                    <p class="text-danger fw-bold">
                        Lưu ý: Hành động này sẽ xóa luôn danh sách món ăn trong đơn và không thể khôi phục!
                    </p>

                    <div class="mt-4 border-top pt-4 d-flex justify-content-center gap-3">
                        @using (Html.BeginForm())
                        {
                            @Html.AntiForgeryToken()

                            <a href="@Url.Action("Index")" class="btn btn-secondary px-4">Hủy bỏ</a>
                            <button type="submit" class="btn btn-danger px-4 fw-bold">
                                <i class="bi bi-trash-fill"></i> Xác nhận Xóa
                            </button>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>